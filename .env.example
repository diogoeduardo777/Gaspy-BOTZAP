# Identifica qual estabelecimento este processo do bot atende (uma linha na tabela `estabelecimentos`).
# Na primeira execução, se não existir nenhum registro no banco, o sistema semeia automaticamente
# usando clients/exemplo.json com este CLIENT_ID.
CLIENT_ID=exemplo

# Pasta onde a sessão do WhatsApp Web fica salva (não apagar entre reinícios, senão precisa
# escanear o QR Code de novo).
SESSION_PATH=./sessions

# Pasta onde o banco SQLite (gaspy.db) é criado.
DATA_PATH=./data

# Só defina isso se quiser apontar para um Chrome/Chromium específico. Se deixar vazio, o
# Chromium baixado automaticamente pelo pacote "puppeteer" é usado.
# PUPPETEER_EXECUTABLE_PATH=

# Porta e senha do painel administrativo web (troque a senha antes de usar em produção).
PAINEL_PORT=3000
PAINEL_SENHA=troque-esta-senha

# Necessário apenas se o estabelecimento estiver no Plano Profissional (atendimento com IA).
# Crie uma chave gratuita em https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
