# Identifica este estabelecimento (uma linha na tabela `estabelecimentos`). É só um apelido
# interno — o cliente final nunca vê. Na primeira execução, o sistema cria o estabelecimento a
# partir do modelo neutro clients/exemplo.json; depois você personaliza TUDO pelo painel.
# Pode deixar como está (um install = um estabelecimento).
CLIENT_ID=meu-negocio

# Pasta onde a sessão do WhatsApp Web fica salva (não apagar entre reinícios, senão precisa
# escanear o QR Code de novo).
SESSION_PATH=./sessions

# Pasta onde o banco SQLite (gaspy.db) é criado.
DATA_PATH=./data

# Só defina isso se quiser apontar para um Chrome/Chromium específico. Se deixar vazio, o
# Chromium baixado automaticamente pelo pacote "puppeteer" é usado (na instalação via Docker, a
# imagem já define isso sozinha para o Chromium do sistema — não precisa mexer aqui).
# PUPPETEER_EXECUTABLE_PATH=

# Alavanca de emergência: se o WhatsApp der o erro "Execution context was destroyed" e não
# conectar de jeito nenhum, fixe aqui uma versão conhecida da página do WhatsApp Web. Escolha
# uma da lista em https://github.com/wppconnect-team/wa-version/tree/main/html (de preferência
# uma SEM "-alpha" no nome), sem o ".html". Deixe vazio para o comportamento automático padrão.
# WWEB_VERSION=2.3000.1023201347

# Porta do painel administrativo web.
PAINEL_PORT=3000

# Onde o painel escuta. Padrão 127.0.0.1 = só o próprio computador acessa (mais seguro).
# Defina PAINEL_HOST=0.0.0.0 só se quiser abrir o painel para outros aparelhos da rede local.
# PAINEL_HOST=127.0.0.1

# Senha do painel: OPCIONAL. Se deixar em branco/removida, a senha é criada no primeiro acesso
# pela própria tela do painel (recomendado). Se definir aqui, essa senha tem prioridade e o
# assistente de criação não aparece — útil para fixar a senha em servidor/produção.
# PAINEL_SENHA=

# Necessário apenas se o estabelecimento estiver no Plano Profissional (atendimento com IA).
# Crie uma chave gratuita em https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Notificações proativas (avisa o cliente quando o status do serviço muda + lembrete de
# retirada de aparelho pronto). Defina NOTIFICACOES_PROATIVAS=false para desligar tudo.
NOTIFICACOES_PROATIVAS=true
# Dias após a conclusão em que os lembretes de retirada são enviados (separados por vírgula).
# A quantidade de números define quantos lembretes no total (ex: "2,5" = dois lembretes).
LEMBRETE_RETIRADA_DIAS=2,5
# De quanto em quanto tempo (minutos) o agendador verifica se há lembretes a enviar.
AGENDADOR_INTERVALO_MIN=60
